#!/usr/bin/env bash
# sway-sandbox — bubblewrap-alapú sandbox Wayland-only grafikus appokhoz Sway alatt.
#
# Használat:
#   sway-sandbox [opciók] -- <parancs> [args...]
#
# Opciók:
#   --name NÉV        sandbox név (XDG app-id-hez, default: a parancs basename-je)
#   --net             engedélyezi a hálózatot (default: nincs háló)
#   --dbus            engedélyezi a session D-Bus-t (szűrt xdg-dbus-proxy-val)
#   --pipewire        engedélyezi a PipeWire socketet (audio + portál-alapú screencast)
#   --home DIR        perzisztens home könyvtár (default: tmpfs, mindent elveszít)
#   --ro PATH         extra read-only bind
#   --rw PATH         extra read-write bind
#   --gpu             DRI/GPU hozzáférés (3D gyorsítás; default: ki)
#   --debug           kiírja a teljes bwrap parancsot
#
# Példák:
#   sway-sandbox --name firefox --net --dbus --pipewire --gpu \
#                --home ~/sandboxes/firefox -- firefox
#   sway-sandbox --name mpv --gpu -- mpv ~/Videos/valami.mkv

set -euo pipefail

# ---------- Argumentumok ----------
APP_NAME=""
ENABLE_NET=0
ENABLE_DBUS=0
ENABLE_PIPEWIRE=0
ENABLE_GPU=0
DEBUG=0
HOME_DIR=""
EXTRA_RO=()
EXTRA_RW=()
CMD=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --name)      APP_NAME="$2"; shift 2 ;;
        --net)       ENABLE_NET=1; shift ;;
        --dbus)      ENABLE_DBUS=1; shift ;;
        --pipewire)  ENABLE_PIPEWIRE=1; shift ;;
        --gpu)       ENABLE_GPU=1; shift ;;
        --home)      HOME_DIR="$(realpath -m "$2")"; shift 2 ;;
        --ro)        EXTRA_RO+=("$(realpath -m "$2")"); shift 2 ;;
        --rw)        EXTRA_RW+=("$(realpath -m "$2")"); shift 2 ;;
        --debug)     DEBUG=1; shift ;;
        --)          shift; CMD=("$@"); break ;;
        *)           echo "Ismeretlen opció: $1" >&2; exit 2 ;;
    esac
done

if [[ ${#CMD[@]} -eq 0 ]]; then
    echo "Nincs parancs megadva. Használat: sway-sandbox [opciók] -- <parancs>" >&2
    exit 2
fi

[[ -z "$APP_NAME" ]] && APP_NAME="$(basename "${CMD[0]}")"
APP_ID="org.sandbox.${APP_NAME}"
INSTANCE_ID="${APP_ID}.$$"

# ---------- Függőség-ellenőrzés ----------
for bin in bwrap swaymsg jq; do
    command -v "$bin" >/dev/null || { echo "Hiányzik: $bin" >&2; exit 1; }
done

# ---------- Sway security-context ellenőrzés ----------
# A Sway 1.9+ támogatja a wp_security_context_manager_v1-et.
# Ha nincs meg, figyelmeztetünk, de továbbmegyünk — a sandbox még mindig hasznos.
HAS_SECCTX=0
if swaymsg -t get_version 2>/dev/null | jq -e '.major > 1 or (.major == 1 and .minor >= 9)' >/dev/null; then
    HAS_SECCTX=1
fi

# ---------- Runtime könyvtárak ----------
REAL_XRD="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
SANDBOX_XRD_HOST="$(mktemp -d -p "$REAL_XRD" "sandbox-${APP_NAME}.XXXXXX")"
SANDBOX_XRD="/run/user/$(id -u)"  # sandboxon belüli path

# Takarítás kilépéskor
cleanup() {
    # D-Bus proxy leállítása, ha fut
    [[ -n "${DBUS_PROXY_PID:-}" ]] && kill "$DBUS_PROXY_PID" 2>/dev/null || true
    # Security-context socket takarítás
    [[ -n "${SECCTX_SOCKET:-}" ]] && rm -f "$SECCTX_SOCKET" || true
    # Runtime dir takarítás
    rm -rf "$SANDBOX_XRD_HOST" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

# ---------- Wayland security-context socket létrehozása ----------
# A security-context-v1 protokoll: a kompozitorhoz kapcsolódva létrehozunk egy
# új listening socketet, amit megjelölünk app_id + instance_id + sandbox_engine
# mezőkkel. Az ezen a socketen érkező klienseket a Sway "sandboxoltnak" tekinti,
# és megtagadja tőlük a privileged protokollokat (screencopy, virtual-keyboard,
# layer-shell, data-control, stb.).
#
# Ehhez egy kis segéd kell: `wayland-security-context` vagy saját C program.
# Itt a `wayland-scanner`-rel generált egyszerű segédet feltételezzük, VAGY a
# `sway-secure-context` nevű közösségi eszközt. Fallbackként a wayland-proxy-t
# is használhatjuk — itt a legrobusztusabb megoldást: saját socketet hozunk
# létre és átadjuk.
#
# A legtisztább gyakorlati megoldás: a `wayland-info`-val ellenőrizzük a
# protokoll jelenlétét, majd a `wlheadless-run`-szerű eszközzel vagy közvetlenül
# libwayland-client-tel kérjük a listen_fd-t. Ehhez itt egy Python segédet
# használunk (pywayland), ha van; különben átadjuk a natív WAYLAND_DISPLAY-t
# figyelmeztetéssel.

WAYLAND_SOCKET_ARG=()
if [[ $HAS_SECCTX -eq 1 ]] && command -v wayland-security-context-helper >/dev/null 2>&1; then
    # Ha van natív helper (pl. saját C program, ami listen_fd-t ad), azt használjuk.
    SECCTX_SOCKET="$SANDBOX_XRD_HOST/wayland-1"
    wayland-security-context-helper \
        --app-id "$APP_ID" \
        --instance-id "$INSTANCE_ID" \
        --sandbox-engine "org.sandbox.bwrap" \
        --listen-socket "$SECCTX_SOCKET" &
    SECCTX_PID=$!
    # Várunk míg a socket létrejön
    for _ in {1..20}; do [[ -S "$SECCTX_SOCKET" ]] && break; sleep 0.05; done
    WAYLAND_SOCKET_ARG=(
        --bind "$SECCTX_SOCKET" "$SANDBOX_XRD/wayland-1"
    )
else
    # Fallback: natív Wayland socket átadása. A sandbox még mindig működik,
    # de a privileged Wayland protokollokat a kliens elvileg elkérheti.
    # A Sway konfigban érdemes a privileged protokollokat allowlistezni
    # ismert appokra (swaymsg seat, stb.) — ez azonban már Sway-config téma.
    NATIVE_WL="$REAL_XRD/${WAYLAND_DISPLAY:-wayland-1}"
    if [[ ! -S "$NATIVE_WL" ]]; then
        echo "HIBA: nincs Wayland socket itt: $NATIVE_WL" >&2
        exit 1
    fi
    [[ $HAS_SECCTX -eq 0 ]] && \
        echo "FIGYELEM: Sway < 1.9 vagy nincs security-context támogatás. A privileged Wayland protokollok elérhetőek lesznek." >&2
    [[ $HAS_SECCTX -eq 1 ]] && \
        echo "FIGYELEM: nincs wayland-security-context-helper telepítve. Natív Wayland socket átadva szűrés nélkül." >&2
    WAYLAND_SOCKET_ARG=(
        --ro-bind "$NATIVE_WL" "$SANDBOX_XRD/wayland-1"
    )
fi

# ---------- D-Bus proxy ----------
DBUS_ARGS=()
if [[ $ENABLE_DBUS -eq 1 ]]; then
    command -v xdg-dbus-proxy >/dev/null || { echo "Hiányzik: xdg-dbus-proxy" >&2; exit 1; }

    PROXY_SOCKET_HOST="$SANDBOX_XRD_HOST/bus"
    PROXY_SOCKET_SANDBOX="$SANDBOX_XRD/bus"

    # Szűrt D-Bus policy: csak a portál és notifikáció, semmi más.
    # Az --own='none' + konkrét --talk= szabályokkal minimalizáljuk a felületet.
    xdg-dbus-proxy \
        "$DBUS_SESSION_BUS_ADDRESS" \
        "$PROXY_SOCKET_HOST" \
        --filter \
        --talk=org.freedesktop.portal.Desktop \
        --talk=org.freedesktop.portal.Documents \
        --talk=org.freedesktop.portal.Flatpak \
        --talk=org.freedesktop.Notifications \
        --talk=org.a11y.Bus \
        --call="org.freedesktop.portal.*=*" \
        --broadcast="org.freedesktop.portal.*=@/org/freedesktop/portal/*" \
        &
    DBUS_PROXY_PID=$!
    for _ in {1..20}; do [[ -S "$PROXY_SOCKET_HOST" ]] && break; sleep 0.05; done

    DBUS_ARGS=(
        --bind "$PROXY_SOCKET_HOST" "$PROXY_SOCKET_SANDBOX"
        --setenv DBUS_SESSION_BUS_ADDRESS "unix:path=$PROXY_SOCKET_SANDBOX"
    )
fi

# ---------- PipeWire ----------
PIPEWIRE_ARGS=()
if [[ $ENABLE_PIPEWIRE -eq 1 ]]; then
    PW_SOCK="$REAL_XRD/pipewire-0"
    if [[ -S "$PW_SOCK" ]]; then
        PIPEWIRE_ARGS=(
            --ro-bind "$PW_SOCK" "$SANDBOX_XRD/pipewire-0"
        )
    fi
fi

# ---------- GPU / DRI ----------
GPU_ARGS=()
if [[ $ENABLE_GPU -eq 1 ]]; then
    GPU_ARGS+=( --dev-bind /dev/dri /dev/dri )
    # shader cache, stb.
    [[ -d /sys/dev/char ]] && GPU_ARGS+=( --ro-bind /sys/dev/char /sys/dev/char )
    [[ -d /sys/devices ]] && GPU_ARGS+=( --ro-bind /sys/devices /sys/devices )
fi

# ---------- Háló ----------
NET_ARGS=( --unshare-net )
if [[ $ENABLE_NET -eq 1 ]]; then
    NET_ARGS=()  # nem unshare-eljük
    # resolv.conf és gépnév
    [[ -f /etc/resolv.conf ]] && NET_ARGS+=( --ro-bind /etc/resolv.conf /etc/resolv.conf )
    [[ -f /etc/hosts ]]       && NET_ARGS+=( --ro-bind /etc/hosts /etc/hosts )
fi

# ---------- Home ----------
HOME_ARGS=()
SANDBOX_HOME="/home/sandbox"
if [[ -n "$HOME_DIR" ]]; then
    mkdir -p "$HOME_DIR"
    HOME_ARGS=( --bind "$HOME_DIR" "$SANDBOX_HOME" )
else
    # Tmpfs home — mindent elveszítünk kilépéskor
    HOME_ARGS=( --tmpfs "$SANDBOX_HOME" )
fi

# Extra bindek
EXTRA_ARGS=()
for p in "${EXTRA_RO[@]}"; do
    [[ -e "$p" ]] && EXTRA_ARGS+=( --ro-bind "$p" "$p" )
done
for p in "${EXTRA_RW[@]}"; do
    [[ -e "$p" ]] && EXTRA_ARGS+=( --bind "$p" "$p" )
done

# ---------- Seccomp ----------
# Egyszerű blokklista: a Flatpak default-jának kivonata. Tiltjuk a keyctl,
# add_key, request_key, bpf, ptrace stb. hívásokat. Ezt BPF-re fordítani
# külön script; itt a beépített bwrap opciókat használjuk ahol lehet.
# (Ha komolyabb policy kell, egy statikusan lefordított .bpf fájlt kell
# átadni --seccomp N-nel; azt itt most mellőzöm a hordozhatóság miatt.)

# ---------- Futtatás ----------
BWRAP_ARGS=(
    # Namespace-ek
    --unshare-user
    --unshare-ipc
    --unshare-pid
    --unshare-uts
    --unshare-cgroup-try
    "${NET_ARGS[@]}"

    # Capabilities: semmi
    --cap-drop ALL

    # Új root: tmpfs
    --tmpfs /
    --proc /proc
    --dev /dev
    --mqueue /dev/mqueue

    # Rendszer read-only bindek
    --ro-bind /usr /usr
    --ro-bind /etc /etc
    --symlink usr/bin /bin
    --symlink usr/bin /sbin
    --symlink usr/lib /lib
    --symlink usr/lib /lib64

    # /var csak részben (fontok, stb.)
    --tmpfs /var
    --ro-bind-try /var/lib/dbus /var/lib/dbus
    --ro-bind-try /var/cache/fontconfig /var/cache/fontconfig

    # /tmp saját
    --tmpfs /tmp

    # XDG_RUNTIME_DIR saját tmpfs-en
    --tmpfs "$SANDBOX_XRD"
    --chmod 0700 "$SANDBOX_XRD"

    # Wayland socket (security-context-tal vagy anélkül)
    "${WAYLAND_SOCKET_ARG[@]}"

    # D-Bus proxy (opcionális)
    "${DBUS_ARGS[@]}"

    # PipeWire (opcionális)
    "${PIPEWIRE_ARGS[@]}"

    # GPU (opcionális)
    "${GPU_ARGS[@]}"

    # Home
    "${HOME_ARGS[@]}"

    # Extra bindek
    "${EXTRA_ARGS[@]}"

    # Környezeti változók
    --clearenv
    --setenv HOME "$SANDBOX_HOME"
    --setenv USER "sandbox"
    --setenv LOGNAME "sandbox"
    --setenv PATH "/usr/bin:/usr/local/bin"
    --setenv SHELL "/bin/bash"
    --setenv LANG "${LANG:-C.UTF-8}"
    --setenv TERM "${TERM:-xterm-256color}"
    --setenv XDG_RUNTIME_DIR "$SANDBOX_XRD"
    --setenv XDG_SESSION_TYPE "wayland"
    --setenv WAYLAND_DISPLAY "wayland-1"
    --setenv XDG_CURRENT_DESKTOP "sway"
    --setenv QT_QPA_PLATFORM "wayland"
    --setenv GDK_BACKEND "wayland"
    --setenv MOZ_ENABLE_WAYLAND "1"
    --setenv SDL_VIDEODRIVER "wayland"
    --setenv CLUTTER_BACKEND "wayland"
    --setenv _JAVA_AWT_WM_NONREPARENTING "1"

    # XWayland explicit kizárva
    --unsetenv DISPLAY
    --unsetenv XAUTHORITY

    # Fontos biztonsági
    --new-session
    --die-with-parent
    --as-pid-1

    # ---- A parancs ----
    "${CMD[@]}"
)

if [[ $DEBUG -eq 1 ]]; then
    printf '%q ' bwrap "${BWRAP_ARGS[@]}"
    echo
fi

exec bwrap "${BWRAP_ARGS[@]}"

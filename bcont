#!/usr/bin/env bash
# bcont — bubblewrap-based Wayland/CLI sandbox for Sway compositor.
# Supports wp_security_context_manager_v1 (Sway >= 1.9).
#
# USAGE:
#   bcont [OPTIONS] -- <command> [args...]
#   bcont <profile>  [OPTIONS] [-- extra-args]
#   bcont list | show <profile> | edit | init | completion bash|zsh

set -euo pipefail

# ── Constants ────────────────────────────────────────────────────────────────
readonly PROG="${0##*/}"
readonly VERSION="1.3.0"
readonly SANDBOX_XRD_INSIDE="/run/user/$(id -u)"
readonly BCONT_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/bcont/profiles"

VERBOSE=0  # declared early so log_debug works in config functions

# ── Colors (only on interactive terminal) ────────────────────────────────────
if [[ -t 2 ]]; then
    C_RESET=$'\033[0m'; C_BOLD=$'\033[1m'
    C_RED=$'\033[31m';  C_YEL=$'\033[33m'; C_CYA=$'\033[36m'; C_GRN=$'\033[32m'
else
    C_RESET=''; C_BOLD=''; C_RED=''; C_YEL=''; C_CYA=''; C_GRN=''
fi

# ── Logging ──────────────────────────────────────────────────────────────────
log_info()  { printf '%s[bcont]%s %s\n'      "$C_CYA$C_BOLD" "$C_RESET" "$*" >&2; }
log_ok()    { printf '%s[bcont]%s %s\n'      "$C_GRN$C_BOLD" "$C_RESET" "$*" >&2; }
log_warn()  { printf '%s[bcont WARN]%s %s\n' "$C_YEL$C_BOLD" "$C_RESET" "$*" >&2; }
log_err()   { printf '%s[bcont ERR]%s %s\n'  "$C_RED$C_BOLD" "$C_RESET" "$*" >&2; }
log_debug() { [[ $VERBOSE -eq 1 ]] && printf '%s[bcont DBG]%s %s\n' "$C_BOLD" "$C_RESET" "$*" >&2 || true; }

die() { log_err "$*"; exit 1; }

# ── Help ─────────────────────────────────────────────────────────────────────
usage() {
    printf '%s%s%s %s — bubblewrap sandbox with Wayland security-context for Sway\n\n' \
        "$C_BOLD" "$PROG" "$C_RESET" "$VERSION"

    printf '%sQUICK START%s\n' "$C_BOLD" "$C_RESET"
    printf '  %s init                   create starter config with example profiles\n' "$PROG"
    printf '  %s list                   list your saved profiles\n' "$PROG"
    printf '  %s firefox                run the [firefox] profile\n' "$PROG"
    printf '  %s firefox --shell        enter the firefox sandbox with your shell\n\n' "$PROG"

    printf '%sPROFILE USAGE%s\n' "$C_BOLD" "$C_RESET"
    printf '  %s <profile>              run profile command as defined in config\n' "$PROG"
    printf '  %s <profile> --shell      drop into a shell inside the sandbox instead\n' "$PROG"
    printf '  %s <profile> -- extra..   append extra args to the profile'\''s command\n' "$PROG"
    printf '  %s <profile> %s-N%s           enable network (even if profile has net=false)\n' "$PROG" "$C_BOLD" "$C_RESET"
    printf '  %s <profile> %s-g%s           enable GPU (even if profile does not set it)\n\n' "$PROG" "$C_BOLD" "$C_RESET"

    printf '%sDIRECT USAGE%s  (no profile)\n' "$C_BOLD" "$C_RESET"
    printf '  %s [FLAGS] -- <command> [args...]\n\n' "$PROG"

    printf '%sFLAGS%s  (all are on/off toggles unless noted with %sVALUE%s)\n' "$C_BOLD" "$C_RESET" "$C_BOLD" "$C_RESET"
    printf '  %s-s, --shell%s        run \$SHELL inside the sandbox instead of the given command\n' "$C_BOLD" "$C_RESET"
    printf '  %s-N, --net%s          allow network access            [default: network blocked]\n' "$C_BOLD" "$C_RESET"
    printf '  %s-d, --dbus%s         allow session D-Bus via portal filter  [default: no D-Bus]\n'  "$C_BOLD" "$C_RESET"
    printf '  %s-D, --system-dbus%s  allow system D-Bus (filtered)         [default: no]\n'       "$C_BOLD" "$C_RESET"
    printf '  %s-p, --pipewire%s     allow PipeWire audio socket            [default: no audio]\n' "$C_BOLD" "$C_RESET"
    printf '  %s-g, --gpu%s          allow full GPU (/dev/dri)       [default: no GPU]\n'         "$C_BOLD" "$C_RESET"
    printf '      %s--gpu-render%s   allow render nodes only (no KMS/DRM)\n'                      "$C_BOLD" "$C_RESET"
    printf '  %s-F, --fido%s         allow FIDO2/U2F security keys (/dev/hidraw*) [default: no]\n' "$C_BOLD" "$C_RESET"
    printf '      %s--cli%s          no Wayland socket (for headless / CLI-only apps)\n'          "$C_BOLD" "$C_RESET"
    printf '  %s-H, --home%s %sDIR%s    persistent home directory       [default: empty tmpfs]\n' "$C_BOLD" "$C_RESET" "$C_BOLD" "$C_RESET"
    printf '      %s--ro%s %sPATH%s     bind a path read-only inside the sandbox (repeatable)\n'  "$C_BOLD" "$C_RESET" "$C_BOLD" "$C_RESET"
    printf '      %s--rw%s %sPATH%s     bind a path read-write inside the sandbox (repeatable)\n' "$C_BOLD" "$C_RESET" "$C_BOLD" "$C_RESET"
    printf '  %s-n, --name%s %sNAME%s   sandbox identity / app-id     [default: command basename]\n' "$C_BOLD" "$C_RESET" "$C_BOLD" "$C_RESET"
    printf '      %s--dry-run%s      print the bwrap command without running it\n'                "$C_BOLD" "$C_RESET"
    printf '  %s-v, --verbose%s      show debug output\n'                                         "$C_BOLD" "$C_RESET"
    printf '  %s-h, --help%s         show this help\n\n'                                          "$C_BOLD" "$C_RESET"

    printf '%sSUBCOMMANDS%s\n' "$C_BOLD" "$C_RESET"
    printf '  %slist%s, %sls%s           list all saved profiles\n'           "$C_BOLD" "$C_RESET" "$C_BOLD" "$C_RESET"
    printf '  %sshow%s <profile>     print a profile'\''s settings\n'         "$C_BOLD" "$C_RESET"
    printf '  %sedit%s               open the config file in \$EDITOR\n'      "$C_BOLD" "$C_RESET"
    printf '  %sinit%s               create a starter config with examples\n' "$C_BOLD" "$C_RESET"
    printf '  %scompletion%s bash|zsh  print a shell completion script\n\n'   "$C_BOLD" "$C_RESET"

    printf '%sEXAMPLES%s\n' "$C_BOLD" "$C_RESET"
    printf '  %s mpv                          # run mpv profile (gpu + ~/Videos ro-bind)\n' "$PROG"
    printf '  %s mpv --shell                  # explore the mpv sandbox in a shell\n' "$PROG"
    printf '  %s firefox -- --private-window  # run firefox with an extra flag\n' "$PROG"
    printf '  %s firefox -N                   # temporarily allow network (profile has net=false)\n' "$PROG"
    printf '  %s --cli --ro ~/src -- make -j  # direct: isolated build, src read-only\n\n' "$PROG"
}

# ── Config / profile support ─────────────────────────────────────────────────

_profile_exists() {
    local name="$1"
    [[ -f "$BCONT_CONFIG" ]] && grep -qE "^\[${name}\][[:space:]]*$" "$BCONT_CONFIG"
}

# Loads a profile into P_* variables.
# Sets: P_NAME P_NET P_DBUS P_PIPEWIRE P_GPU P_CLI P_HOME P_RO[] P_RW[] P_CMD[]
load_profile() {
    local target="$1" in_section=0 found=0
    P_NET=0; P_DBUS=0; P_SYSTEM_DBUS=0; P_PIPEWIRE=0; P_GPU=0; P_CLI=0; P_FIDO=0
    P_HOME=""; P_RO=(); P_RW=(); P_CMD=(); P_NAME="$target"

    [[ ! -f "$BCONT_CONFIG" ]] && die "Config not found: $BCONT_CONFIG — run: $PROG init"

    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line%%\#*}"                          # strip comments
        line="${line#"${line%%[! ]*}"}"              # ltrim
        line="${line%"${line##*[! ]}"}"              # rtrim
        [[ -z "$line" ]] && continue

        if [[ "$line" =~ ^\[([^]]+)\][[:space:]]*$ ]]; then
            local sec="${BASH_REMATCH[1]}"
            sec="${sec#"${sec%%[! ]*}"}"; sec="${sec%"${sec##*[! ]}"}"
            if [[ "$sec" == "$target" ]]; then
                in_section=1; found=1
            elif [[ $in_section -eq 1 ]]; then
                break
            else
                in_section=0
            fi
            continue
        fi

        [[ $in_section -eq 0 ]] && continue

        if [[ "$line" =~ ^([a-zA-Z_-]+)[[:space:]]*=[[:space:]]*(.*) ]]; then
            local key="${BASH_REMATCH[1]}"
            local val="${BASH_REMATCH[2]}"
            val="${val%"${val##*[! ]}"}"         # rtrim
            val="${val#\"}"; val="${val%\"}"     # strip double quotes
            val="${val#\'}"; val="${val%\'}"     # strip single quotes
            val="${val/#\~/$HOME}"               # expand leading ~

            case "$key" in
                name)     P_NAME="$val" ;;
                net)      [[ "$val" =~ ^(true|1|yes)$ ]]  && P_NET=1 ;;
                dbus)        [[ "$val" =~ ^(true|1|yes)$ ]] && P_DBUS=1 ;;
                system_dbus) [[ "$val" =~ ^(true|1|yes)$ ]] && P_SYSTEM_DBUS=1 ;;
                pipewire)    [[ "$val" =~ ^(true|1|yes)$ ]] && P_PIPEWIRE=1 ;;
                gpu)
                    case "$val" in
                        true|full|1|yes) P_GPU=1 ;;
                        render)          P_GPU=2 ;;
                    esac ;;
                cli)  [[ "$val" =~ ^(true|1|yes)$ ]] && P_CLI=1 ;;
                fido) [[ "$val" =~ ^(true|1|yes)$ ]] && P_FIDO=1 ;;
                home) P_HOME="$val" ;;
                ro)   P_RO+=("$val") ;;
                rw)   P_RW+=("$val") ;;
                cmd)  read -ra P_CMD <<< "$val" ;;
            esac
        fi
    done < "$BCONT_CONFIG"

    [[ $found -eq 0 ]] && die "Profile '$target' not found in $BCONT_CONFIG"
    log_debug "Loaded profile: $target"
}

list_profiles() {
    if [[ ! -f "$BCONT_CONFIG" ]]; then
        log_warn "No config file yet — run: $PROG init"
        return
    fi
    printf '%sProfiles%s  (%s)\n' "$C_BOLD" "$C_RESET" "$BCONT_CONFIG"
    local count=0
    while IFS= read -r line; do
        if [[ "$line" =~ ^\[([^]]+)\] ]]; then
            printf '  %s%s%s\n' "$C_CYA" "${BASH_REMATCH[1]}" "$C_RESET"
            (( count++ )) || true
        fi
    done < "$BCONT_CONFIG"
    [[ $count -eq 0 ]] && printf '  (none — add [name] sections to %s)\n' "$BCONT_CONFIG"
    return 0
}

show_profile() {
    local name="$1"
    [[ ! -f "$BCONT_CONFIG" ]] && die "No config file: $BCONT_CONFIG"
    local in_section=0 found=0
    printf '%s[%s]%s\n' "$C_BOLD$C_CYA" "$name" "$C_RESET"
    while IFS= read -r line || [[ -n "$line" ]]; do
        local stripped="${line%%\#*}"
        stripped="${stripped#"${stripped%%[! ]*}"}"; stripped="${stripped%"${stripped##*[! ]}"}"
        if [[ "$stripped" =~ ^\[([^]]+)\] ]]; then
            local sec="${BASH_REMATCH[1]}"
            sec="${sec#"${sec%%[! ]*}"}"; sec="${sec%"${sec##*[! ]}"}"
            if [[ "$sec" == "$name" ]]; then
                in_section=1; found=1
            elif [[ $in_section -eq 1 ]]; then
                break
            else
                in_section=0
            fi
            continue
        fi
        [[ $in_section -eq 1 && -n "$stripped" ]] && printf '  %s\n' "$stripped"
    done < "$BCONT_CONFIG"
    [[ $found -eq 0 ]] && die "Profile '$name' not found in $BCONT_CONFIG"
    return 0
}

cmd_init() {
    local quiet="${1:-}"
    if [[ -f "$BCONT_CONFIG" ]] && [[ "$quiet" != "--quiet" ]]; then
        log_warn "Config already exists: $BCONT_CONFIG"
        printf 'Overwrite? [y/N] '
        read -r _ans
        [[ "$_ans" =~ ^[Yy]$ ]] || { log_info "Aborted."; exit 0; }
    fi
    mkdir -p "$(dirname "$BCONT_CONFIG")"
    cat > "$BCONT_CONFIG" << 'EOF'
# bcont profiles — ~/.config/bcont/profiles
#
# Keys (all optional):
#   name      = override sandbox name (default: profile section name)
#   net       = true | false
#   dbus        = true | false     (session D-Bus portals proxy)
#   system_dbus = true | false     (system D-Bus: NetworkManager, UPower, login1, bluez)
#   pipewire  = true | false
#   gpu       = full | render | false
#   cli       = true | false       (no Wayland socket)
#   fido      = true | false       (FIDO2/U2F security keys via /dev/hidraw*)
#   home      = ~/path             (persistent home; omit for tmpfs)
#   ro        = ~/path             (read-only bind, repeatable)
#   rw        = ~/path             (read-write bind, repeatable)
#   cmd       = command [args]
#
# Usage:
#   bcont firefox                    # run this profile
#   bcont firefox -N                 # profile + flag override
#   bcont firefox -- --private-window  # profile + extra cmd args

[firefox]
net         = true
dbus        = true
system_dbus = true
pipewire    = true
gpu         = full
fido        = true
home        = ~/.local/share/bcont/firefox
cmd         = firefox

[mpv]
gpu       = full
ro        = ~/Videos
cmd       = mpv

[foot]
cmd       = foot

[zathura]
gpu       = render
ro        = ~/Documents
cmd       = zathura
EOF
    log_ok "Created: $BCONT_CONFIG"
    printf 'Edit with:  %s edit\n' "$PROG"
    printf 'List with:  %s list\n' "$PROG"
}

cmd_completion() {
    local shell="${1:-bash}"
    case "$shell" in
        bash) cat << 'BASH_COMP'
# bcont bash completion — source this or drop in ~/.bash_completion.d/bcont
_bcont_profiles() {
    local cfg="${XDG_CONFIG_HOME:-$HOME/.config}/bcont/profiles"
    [[ -f "$cfg" ]] || return
    grep -oE '^\[[^]]+\]' "$cfg" | tr -d '[]'
}
_bcont() {
    local cur="${COMP_WORDS[COMP_CWORD]}" prev="${COMP_WORDS[COMP_CWORD-1]}"
    local subcmds="list ls show edit init completion"
    local opts="-n --name -N --net -d --dbus -D --system-dbus -p --pipewire -F --fido -g --gpu --gpu-render -s --shell -H --home --ro --rw --cli --dry-run -v --verbose -h --help"
    if [[ $COMP_CWORD -eq 1 ]]; then
        COMPREPLY=( $(compgen -W "$subcmds $(_bcont_profiles) $opts" -- "$cur") )
    elif [[ "$prev" == "show" ]]; then
        COMPREPLY=( $(compgen -W "$(_bcont_profiles)" -- "$cur") )
    elif [[ "$prev" == "completion" ]]; then
        COMPREPLY=( $(compgen -W "bash zsh" -- "$cur") )
    elif [[ "$prev" == "-H" || "$prev" == "--home" || "$prev" == "--ro" || "$prev" == "--rw" ]]; then
        COMPREPLY=( $(compgen -d -- "$cur") )
    else
        COMPREPLY=( $(compgen -W "$opts" -- "$cur") )
    fi
}
complete -F _bcont bcont
BASH_COMP
        ;;
        zsh) cat << 'ZSH_COMP'
# bcont zsh completion — save as a file named _bcont on your fpath, or source it
_bcont() {
    local cfg="${XDG_CONFIG_HOME:-$HOME/.config}/bcont/profiles"
    local -a profiles=()
    if [[ -f "$cfg" ]]; then
        while IFS= read -r line; do
            [[ "$line" =~ ^\[([^]]+)\] ]] && profiles+=("${match[1]}")
        done < "$cfg"
    fi
    local -a subcmds=(
        'list:List saved profiles'
        'ls:List saved profiles (alias)'
        'show:Show profile settings'
        'edit:Open config in $EDITOR'
        'init:Create starter config'
        'completion:Print shell completion script'
    )
    _arguments -s \
        '1: :->first' \
        '*: :->rest' && return
    case "$state" in
        first)
            _describe 'subcommand' subcmds
            _describe 'profile' profiles
            _arguments \
                {-n,--name}'[Sandbox name]:name' \
                {-N,--net}'[Enable network]' \
                {-d,--dbus}'[Session D-Bus portals proxy]' \
                {-D,--system-dbus}'[System D-Bus (filtered)]' \
                {-p,--pipewire}'[PipeWire socket]' \
                {-F,--fido}'[FIDO2/U2F security keys]' \
                {-g,--gpu}'[Full GPU access]' \
                '--gpu-render[Render nodes only]' \
                {-s,--shell}'[Run shell instead of command]' \
                {-H,--home}'[Persistent home]:dir:_directories' \
                '--ro[Read-only bind]:path:_files' \
                '--rw[Read-write bind]:path:_files' \
                '--cli[Force CLI mode]' \
                '--dry-run[Print command, do not run]' \
                {-v,--verbose}'[Verbose output]' \
                {-h,--help}'[Show help]'
            ;;
        rest)
            case "${words[2]}" in
                show)       _describe 'profile' profiles ;;
                completion) _values 'shell' bash zsh ;;
            esac
            ;;
    esac
}
_bcont "$@"
ZSH_COMP
        ;;
        *) die "Unknown shell: $shell (supported: bash, zsh)" ;;
    esac
}

# ── Subcommand dispatch ───────────────────────────────────────────────────────
PROFILE_NAME=""

case "${1:-}" in
    list|ls)
        list_profiles; exit 0 ;;
    show)
        [[ -z "${2:-}" ]] && die "Usage: $PROG show <profile>"
        show_profile "$2"; exit 0 ;;
    edit)
        [[ -f "$BCONT_CONFIG" ]] || cmd_init --quiet
        exec "${EDITOR:-vi}" "$BCONT_CONFIG" ;;
    init)
        cmd_init; exit 0 ;;
    completion)
        cmd_completion "${2:-bash}"; exit 0 ;;
    -h|--help)
        usage; exit 0 ;;
    ""|--)
        : ;;
    -*)
        : ;;  # option — normal processing below
    *)
        if _profile_exists "$1"; then
            PROFILE_NAME="$1"; shift
        fi
        ;;
esac

# ── Argument parsing ──────────────────────────────────────────────────────────
APP_NAME=""
ENABLE_NET=0
ENABLE_DBUS=0
ENABLE_SYSTEM_DBUS=0
ENABLE_PIPEWIRE=0
ENABLE_GPU=0        # 0=none, 1=full, 2=render-only
ENABLE_FIDO=0
FORCE_CLI=0
DRY_RUN=0
SHELL_OVERRIDE=0
HOME_DIR=""
EXTRA_RO=()
EXTRA_RW=()
CMD=()
P_CMD=()

# Apply profile defaults before flag parsing (flags will override)
if [[ -n "$PROFILE_NAME" ]]; then
    load_profile "$PROFILE_NAME"
    APP_NAME="${P_NAME:-$PROFILE_NAME}"
    [[ $P_NET         -eq 1 ]] && ENABLE_NET=1
    [[ $P_DBUS        -eq 1 ]] && ENABLE_DBUS=1
    [[ $P_SYSTEM_DBUS -eq 1 ]] && ENABLE_SYSTEM_DBUS=1
    [[ $P_PIPEWIRE    -eq 1 ]] && ENABLE_PIPEWIRE=1
    [[ $P_GPU      -gt 0 ]] && ENABLE_GPU=$P_GPU
    [[ $P_FIDO     -eq 1 ]] && ENABLE_FIDO=1
    [[ $P_CLI      -eq 1 ]] && FORCE_CLI=1
    [[ -n "$P_HOME"       ]] && HOME_DIR="$P_HOME"
    EXTRA_RO+=("${P_RO[@]+"${P_RO[@]}"}")
    EXTRA_RW+=("${P_RW[@]+"${P_RW[@]}"}")
fi

_short=n:NdDpFgsH:vh
_long=name:,net,dbus,system-dbus,pipewire,fido,gpu,gpu-render,shell,home:,ro:,rw:,cli,dry-run,verbose,help

if ! PARSED=$(getopt -o "$_short" -l "$_long" -n "$PROG" -- "$@"); then
    printf 'Run: %s --help\n' "$PROG" >&2; exit 2
fi
eval set -- "$PARSED"

while true; do
    case "$1" in
        -n|--name)       APP_NAME="$2";                         shift 2 ;;
        -N|--net)        ENABLE_NET=1;                          shift   ;;
        -d|--dbus)        ENABLE_DBUS=1;                        shift   ;;
        -D|--system-dbus) ENABLE_SYSTEM_DBUS=1;                shift   ;;
        -p|--pipewire)    ENABLE_PIPEWIRE=1;                   shift   ;;
        -F|--fido)        ENABLE_FIDO=1;                       shift   ;;
        -g|--gpu)        ENABLE_GPU=1;                          shift   ;;
           --gpu-render) ENABLE_GPU=2;                          shift   ;;
        -s|--shell)      SHELL_OVERRIDE=1;                      shift   ;;
        -H|--home)       HOME_DIR="$2";                         shift 2 ;;
           --ro)         EXTRA_RO+=("$2");                      shift 2 ;;
           --rw)         EXTRA_RW+=("$2");                      shift 2 ;;
           --cli)        FORCE_CLI=1;                           shift   ;;
           --dry-run)    DRY_RUN=1;                             shift   ;;
        -v|--verbose)    VERBOSE=1;                             shift   ;;
        -h|--help)       usage; exit 0 ;;
        --)              shift; CMD=("$@"); break ;;
        *)               die "Unknown option: $1 — run: ${PROG} --help" ;;
    esac
done

# Merge profile cmd with extra args from --
if [[ -n "$PROFILE_NAME" ]]; then
    if [[ ${#P_CMD[@]} -gt 0 && ${#CMD[@]} -gt 0 ]]; then
        CMD=("${P_CMD[@]}" "${CMD[@]}")   # profile cmd + appended args
    elif [[ ${#P_CMD[@]} -gt 0 ]]; then
        CMD=("${P_CMD[@]}")
    fi
fi

# --shell overrides the command entirely with the user's shell
if [[ $SHELL_OVERRIDE -eq 1 ]]; then
    CMD=("${SHELL:-/bin/bash}")
fi

[[ ${#CMD[@]} -eq 0 ]] && { usage; die "No command specified."; }

# ── APP_NAME validation ───────────────────────────────────────────────────────
[[ -z "$APP_NAME" ]] && APP_NAME="$(basename "${CMD[0]}")"

if [[ ! "$APP_NAME" =~ ^[a-zA-Z0-9_-]+$ ]]; then
    die "Invalid --name value: '$APP_NAME' (only [a-zA-Z0-9_-] allowed)"
fi

APP_ID="org.sandbox.${APP_NAME}"
INSTANCE_ID="${APP_ID}.$$"

# ── Wayland mode detection ────────────────────────────────────────────────────
WAYLAND_MODE=1
if [[ $FORCE_CLI -eq 1 ]]; then
    WAYLAND_MODE=0
    log_info "CLI mode: --cli flag set, no Wayland socket."
elif [[ -z "${WAYLAND_DISPLAY:-}" ]]; then
    WAYLAND_MODE=0
    log_info "CLI mode: WAYLAND_DISPLAY is empty/unset, no Wayland socket."
fi

if [[ $WAYLAND_MODE -eq 0 ]]; then
    [[ $ENABLE_DBUS     -eq 1 ]] && log_warn "--dbus is active in CLI mode (D-Bus portal proxy still works)."
    [[ $ENABLE_PIPEWIRE -eq 1 ]] && log_warn "--pipewire in CLI mode: useful for audio-only access."
fi

# ── Dependency checks ─────────────────────────────────────────────────────────
_check_dep() {
    local bin="$1" optional="${2:-0}"
    if ! command -v "$bin" &>/dev/null; then
        [[ $optional -eq 1 ]] && { log_warn "Optional dependency missing: $bin"; return 1; }
        die "Missing dependency: $bin — please install it and retry."
    fi
    return 0
}

_check_dep bwrap
_check_dep jq
[[ $WAYLAND_MODE -eq 1 ]] && _check_dep swaymsg
[[ $ENABLE_DBUS -eq 1 || $ENABLE_SYSTEM_DBUS -eq 1 ]] && _check_dep xdg-dbus-proxy

HAS_SECCTX_HELPER=0
if [[ $WAYLAND_MODE -eq 1 ]]; then
    _check_dep wayland-security-context-helper 1 && HAS_SECCTX_HELPER=1
fi

# ── Sway security-context version check ──────────────────────────────────────
HAS_SWAY_SECCTX=0
if [[ $WAYLAND_MODE -eq 1 ]]; then
    if swaymsg -t get_version 2>/dev/null \
            | jq -e '.major > 1 or (.major == 1 and .minor >= 9)' &>/dev/null; then
        HAS_SWAY_SECCTX=1
        log_debug "Sway >= 1.9 detected, wp_security_context_manager_v1 available."
    else
        log_warn "Sway < 1.9 or unavailable — running without security-context."
    fi
fi

# ── Runtime directory and cleanup ─────────────────────────────────────────────
REAL_XRD="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
SANDBOX_XRD_HOST="$(mktemp -d -p "$REAL_XRD" "bcont-${APP_NAME}.XXXXXX")"
chmod 700 "$SANDBOX_XRD_HOST"
log_debug "Sandbox runtime dir (host): $SANDBOX_XRD_HOST"

DBUS_PROXY_PID=""
SYSTEM_DBUS_PROXY_PID=""
SECCTX_PID=""
SECCTX_SOCKET=""

cleanup() {
    log_debug "Cleanup..."

    if [[ -n "$DBUS_PROXY_PID" ]] && kill -0 "$DBUS_PROXY_PID" 2>/dev/null; then
        kill "$DBUS_PROXY_PID" 2>/dev/null || true
        wait "$DBUS_PROXY_PID" 2>/dev/null || true
    fi

    if [[ -n "$SYSTEM_DBUS_PROXY_PID" ]] && kill -0 "$SYSTEM_DBUS_PROXY_PID" 2>/dev/null; then
        kill "$SYSTEM_DBUS_PROXY_PID" 2>/dev/null || true
        wait "$SYSTEM_DBUS_PROXY_PID" 2>/dev/null || true
    fi

    if [[ -n "$SECCTX_PID" ]] && kill -0 "$SECCTX_PID" 2>/dev/null; then
        kill "$SECCTX_PID" 2>/dev/null || true
        wait "$SECCTX_PID" 2>/dev/null || true
    fi

    [[ -n "$SECCTX_SOCKET" ]] && rm -f "$SECCTX_SOCKET" 2>/dev/null || true
    rm -rf "$SANDBOX_XRD_HOST" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

# ── Wayland socket setup ──────────────────────────────────────────────────────
WAYLAND_SOCKET_ARGS=()
WAYLAND_ENV_ARGS=()

if [[ $WAYLAND_MODE -eq 1 ]]; then
    if [[ $HAS_SWAY_SECCTX -eq 1 && $HAS_SECCTX_HELPER -eq 1 ]]; then
        SECCTX_SOCKET="$SANDBOX_XRD_HOST/wayland-1"

        wayland-security-context-helper \
            --app-id         "$APP_ID" \
            --instance-id    "$INSTANCE_ID" \
            --sandbox-engine "org.sandbox.bwrap" \
            --listen-socket  "$SECCTX_SOCKET" &
        SECCTX_PID=$!

        _tries=0
        while [[ $_tries -lt 40 ]]; do
            [[ -S "$SECCTX_SOCKET" ]] && break
            if ! kill -0 "$SECCTX_PID" 2>/dev/null; then
                die "wayland-security-context-helper exited immediately (socket: $SECCTX_SOCKET)"
            fi
            sleep 0.05
            (( _tries++ )) || true
        done
        [[ -S "$SECCTX_SOCKET" ]] \
            || die "Timeout: security-context socket not created: $SECCTX_SOCKET"

        log_ok "Security-context socket ready: $SECCTX_SOCKET (PID: $SECCTX_PID)"

        WAYLAND_SOCKET_ARGS=(
            --bind "$SECCTX_SOCKET" "$SANDBOX_XRD_INSIDE/wayland-1"
        )
    else
        _NATIVE_WL="$REAL_XRD/${WAYLAND_DISPLAY:-wayland-1}"
        [[ -S "$_NATIVE_WL" ]] || die "Wayland socket not found: $_NATIVE_WL"

        if [[ $HAS_SWAY_SECCTX -eq 1 ]]; then
            log_warn "wayland-security-context-helper not installed — native socket passed through unfiltered!"
        else
            log_warn "Sway < 1.9 — privileged Wayland protocols will be accessible!"
        fi

        WAYLAND_SOCKET_ARGS=(
            --ro-bind "$_NATIVE_WL" "$SANDBOX_XRD_INSIDE/wayland-1"
        )
    fi

    WAYLAND_ENV_ARGS=(
        --setenv XDG_SESSION_TYPE            "wayland"
        --setenv WAYLAND_DISPLAY             "wayland-1"
        --setenv XDG_CURRENT_DESKTOP         "sway"
        --setenv QT_QPA_PLATFORM             "wayland"
        --setenv GDK_BACKEND                 "wayland"
        --setenv MOZ_ENABLE_WAYLAND          "1"
        --setenv SDL_VIDEODRIVER             "wayland"
        --setenv CLUTTER_BACKEND             "wayland"
        --setenv _JAVA_AWT_WM_NONREPARENTING "1"
        --unsetenv DISPLAY
        --unsetenv XAUTHORITY
    )
else
    WAYLAND_ENV_ARGS=(
        --unsetenv WAYLAND_DISPLAY
        --unsetenv DISPLAY
        --unsetenv XAUTHORITY
        --unsetenv XDG_SESSION_TYPE
        --unsetenv QT_QPA_PLATFORM
        --unsetenv GDK_BACKEND
        --unsetenv MOZ_ENABLE_WAYLAND
        --unsetenv SDL_VIDEODRIVER
        --unsetenv CLUTTER_BACKEND
    )
    log_debug "CLI mode: Wayland envs cleared, no socket bound."
fi

# ── D-Bus proxy ───────────────────────────────────────────────────────────────
DBUS_ARGS=()
if [[ $ENABLE_DBUS -eq 1 ]]; then
    PROXY_SOCKET_HOST="$SANDBOX_XRD_HOST/bus"
    PROXY_SOCKET_INSIDE="$SANDBOX_XRD_INSIDE/bus"

    xdg-dbus-proxy \
        "$DBUS_SESSION_BUS_ADDRESS" \
        "$PROXY_SOCKET_HOST" \
        --filter \
        --talk=org.freedesktop.portal.Desktop \
        --talk=org.freedesktop.portal.Documents \
        --talk=org.freedesktop.portal.Flatpak \
        --talk=org.freedesktop.portal.ScreenCast \
        --talk=org.freedesktop.portal.RemoteDesktop \
        --talk=org.freedesktop.Notifications \
        --talk=org.a11y.Bus \
        --call="org.freedesktop.portal.*=*" \
        --broadcast="org.freedesktop.portal.*=@/org/freedesktop/portal/*" \
        &
    DBUS_PROXY_PID=$!

    _tries=0
    while [[ $_tries -lt 40 ]]; do
        [[ -S "$PROXY_SOCKET_HOST" ]] && break
        if ! kill -0 "$DBUS_PROXY_PID" 2>/dev/null; then
            die "xdg-dbus-proxy exited immediately"
        fi
        sleep 0.05
        (( _tries++ )) || true
    done
    [[ -S "$PROXY_SOCKET_HOST" ]] \
        || die "D-Bus proxy socket not created: $PROXY_SOCKET_HOST"

    log_ok "D-Bus proxy ready (PID: $DBUS_PROXY_PID)"

    DBUS_ARGS=(
        --bind   "$PROXY_SOCKET_HOST"     "$PROXY_SOCKET_INSIDE"
        --setenv DBUS_SESSION_BUS_ADDRESS "unix:path=$PROXY_SOCKET_INSIDE"
    )
fi

# ── System D-Bus proxy ────────────────────────────────────────────────────────
SYSTEM_DBUS_ARGS=()
if [[ $ENABLE_SYSTEM_DBUS -eq 1 ]]; then
    _SYSBUS_SOCK=/run/dbus/system_bus_socket
    [[ -S "$_SYSBUS_SOCK" ]] || die "System D-Bus socket not found: $_SYSBUS_SOCK"

    SYSTEM_PROXY_SOCKET_HOST="$SANDBOX_XRD_HOST/system_bus_socket"

    xdg-dbus-proxy \
        "unix:path=$_SYSBUS_SOCK" \
        "$SYSTEM_PROXY_SOCKET_HOST" \
        --filter \
        --talk=org.freedesktop.NetworkManager \
        --talk=org.freedesktop.UPower \
        --talk=org.freedesktop.login1 \
        --talk=org.freedesktop.PolicyKit1 \
        --talk=org.bluez \
        --call="org.freedesktop.NetworkManager=*" \
        --call="org.freedesktop.UPower=*" \
        --call="org.freedesktop.login1=*" \
        --broadcast="org.freedesktop.NetworkManager.*=@/org/freedesktop/NetworkManager/*" \
        --broadcast="org.freedesktop.UPower.*=@/org/freedesktop/UPower/*" \
        --broadcast="org.freedesktop.login1.*=@/org/freedesktop/login1/*" \
        &
    SYSTEM_DBUS_PROXY_PID=$!

    _tries=0
    while [[ $_tries -lt 40 ]]; do
        [[ -S "$SYSTEM_PROXY_SOCKET_HOST" ]] && break
        if ! kill -0 "$SYSTEM_DBUS_PROXY_PID" 2>/dev/null; then
            die "xdg-dbus-proxy (system bus) exited immediately"
        fi
        sleep 0.05
        (( _tries++ )) || true
    done
    [[ -S "$SYSTEM_PROXY_SOCKET_HOST" ]] \
        || die "System D-Bus proxy socket not created: $SYSTEM_PROXY_SOCKET_HOST"

    log_ok "System D-Bus proxy ready (PID: $SYSTEM_DBUS_PROXY_PID)"

    SYSTEM_DBUS_ARGS=(
        --bind "$SYSTEM_PROXY_SOCKET_HOST" "$_SYSBUS_SOCK"
    )
fi

# ── PipeWire ──────────────────────────────────────────────────────────────────
PIPEWIRE_ARGS=()
if [[ $ENABLE_PIPEWIRE -eq 1 ]]; then
    PW_SOCK="$REAL_XRD/pipewire-0"
    if [[ -S "$PW_SOCK" ]]; then
        PIPEWIRE_ARGS=( --ro-bind "$PW_SOCK" "$SANDBOX_XRD_INSIDE/pipewire-0" )
        log_debug "PipeWire socket: $PW_SOCK"
    else
        log_warn "PipeWire socket not found: $PW_SOCK — --pipewire has no effect."
    fi
fi

# ── GPU / DRI ─────────────────────────────────────────────────────────────────
# _bind_nvidia adds /dev/nvidia* character devices required by the NVIDIA
# Vulkan/GL ICD (nvidiactl, nvidia0..N, nvidia-modeset, nvidia-uvm, etc.).
# Without these, vkEnumeratePhysicalDevices returns zero inside the sandbox.
_bind_nvidia() {
    local found=0
    for _nv in /dev/nvidia*; do
        [[ -c "$_nv" ]] || continue
        GPU_ARGS+=( --dev-bind "$_nv" "$_nv" )
        found=1
    done
    # nvidia-caps/ holds character devices used by NVML (nvidia-smi, monitoring).
    # Skipped by the glob above because it is a directory, not a char device.
    if [[ -d /dev/nvidia-caps ]]; then
        GPU_ARGS+=( --dev-bind /dev/nvidia-caps /dev/nvidia-caps )
        found=1
    fi
    [[ $found -eq 1 ]] && log_debug "NVIDIA devices bound (/dev/nvidia*, /dev/nvidia-caps)."
}

_bind_dri_sysfs_for_node() {
    # Resolve a DRI device node to its sysfs hardware-device directory and bind
    # only that subtree — avoids binding /sys/devices wholesale, which hangs on
    # systems with certain hardware (Surface SAM, IME, proprietary platform buses).
    local devnode="$1" hex_maj hex_min major minor charlink devpath hwdev
    hex_maj=$(stat -c "%t" "$devnode" 2>/dev/null) || return 0
    hex_min=$(stat -c "%T" "$devnode" 2>/dev/null) || return 0
    [[ -n "$hex_maj" && -n "$hex_min" ]] || return 0
    major=$(( 16#$hex_maj ))
    minor=$(( 16#$hex_min ))
    charlink="/sys/dev/char/${major}:${minor}"
    [[ -L "$charlink" ]] || return 0
    devpath="$(readlink -f "$charlink")" || return 0
    [[ -d "$devpath" ]] || return 0
    # Layout: /sys/devices/…/<hw-device>/drm/renderD128
    # Two levels up reaches the hardware device directory (PCI slot, platform dev, etc.)
    hwdev="$(dirname "$(dirname "$devpath")")"
    [[ "$hwdev" =~ ^/sys/devices/. ]] || return 0
    [[ -d "$hwdev" ]] || return 0
    GPU_ARGS+=( --ro-bind "$hwdev" "$hwdev" )
    log_debug "GPU sysfs: $hwdev"
}

_bind_gpu_sysfs() {
    # Bind per-device sysfs subtrees (passed as args) instead of /sys/devices.
    local _node
    for _node in "$@"; do
        _bind_dri_sysfs_for_node "$_node"
    done
    [[ -d /sys/dev/char      ]] && GPU_ARGS+=( --ro-bind /sys/dev/char      /sys/dev/char      )
    [[ -d /sys/class/drm     ]] && GPU_ARGS+=( --ro-bind /sys/class/drm     /sys/class/drm     )
    [[ -d /sys/bus/pci       ]] && GPU_ARGS+=( --ro-bind /sys/bus/pci       /sys/bus/pci       )
    [[ -d /sys/module/nvidia ]] && GPU_ARGS+=( --ro-bind /sys/module/nvidia /sys/module/nvidia )
}

GPU_ARGS=()
if [[ $ENABLE_GPU -eq 1 ]]; then
    GPU_ARGS+=( --dev-bind /dev/dri /dev/dri )
    _bind_nvidia
    _dri_nodes=()
    for _n in /dev/dri/card* /dev/dri/renderD*; do
        [[ -c "$_n" ]] && _dri_nodes+=("$_n")
    done
    _bind_gpu_sysfs "${_dri_nodes[@]+"${_dri_nodes[@]}"}"
    log_debug "GPU: full /dev/dri (card* + renderD*)"
elif [[ $ENABLE_GPU -eq 2 ]]; then
    _render_nodes=()
    for _node in /dev/dri/renderD*; do
        if [[ -c "$_node" ]]; then
            GPU_ARGS+=( --dev-bind "$_node" "$_node" )
            _render_nodes+=("$_node")
        fi
    done
    if [[ ${#_render_nodes[@]} -eq 0 ]]; then
        log_warn "No /dev/dri/renderD* nodes found — --gpu-render has no effect."
    else
        _bind_nvidia
        _bind_gpu_sysfs "${_render_nodes[@]}"
        log_debug "GPU: render-only nodes bound."
    fi
fi

# ── FIDO2/U2F (HID security keys) ────────────────────────────────────────────
# Chromium-based browsers talk to FIDO2/U2F keys directly via /dev/hidraw*.
# They enumerate /sys/class/hidraw to discover devices and follow symlinks into
# /sys/devices to read HID attributes; we bind the per-device sysfs subtree
# rather than /sys/devices wholesale.
_bind_hid_sysfs_for_node() {
    local devnode="$1" hex_maj hex_min major minor charlink devpath hwdev
    hex_maj=$(stat -c "%t" "$devnode" 2>/dev/null) || return 0
    hex_min=$(stat -c "%T" "$devnode" 2>/dev/null) || return 0
    [[ -n "$hex_maj" && -n "$hex_min" ]] || return 0
    major=$(( 16#$hex_maj ))
    minor=$(( 16#$hex_min ))
    charlink="/sys/dev/char/${major}:${minor}"
    [[ -L "$charlink" ]] || return 0
    devpath="$(readlink -f "$charlink")" || return 0
    [[ -d "$devpath" ]] || return 0
    # Layout: /sys/devices/…/<hw-device>/hidraw/hidraw0
    hwdev="$(dirname "$(dirname "$devpath")")"
    [[ "$hwdev" =~ ^/sys/devices/. ]] || return 0
    [[ -d "$hwdev" ]] || return 0
    FIDO_ARGS+=( --ro-bind "$hwdev" "$hwdev" )
    log_debug "FIDO sysfs: $hwdev"
}

FIDO_ARGS=()
if [[ $ENABLE_FIDO -eq 1 ]]; then
    _fido_count=0
    for _h in /dev/hidraw*; do
        [[ -c "$_h" ]] || continue
        FIDO_ARGS+=( --dev-bind "$_h" "$_h" )
        _bind_hid_sysfs_for_node "$_h"
        (( _fido_count++ )) || true
    done
    if [[ $_fido_count -eq 0 ]]; then
        log_warn "No /dev/hidraw* devices found — --fido has no effect."
    else
        [[ -d /sys/class/hidraw ]] && FIDO_ARGS+=( --ro-bind /sys/class/hidraw /sys/class/hidraw )
        log_debug "FIDO2/U2F: bound $_fido_count /dev/hidraw* device(s)"
    fi
fi

# ── Network ───────────────────────────────────────────────────────────────────
NET_ARGS=( --unshare-net )
if [[ $ENABLE_NET -eq 1 ]]; then
    NET_ARGS=()
    [[ -f /etc/resolv.conf   ]] && NET_ARGS+=( --ro-bind /etc/resolv.conf   /etc/resolv.conf   )
    [[ -f /etc/hosts         ]] && NET_ARGS+=( --ro-bind /etc/hosts         /etc/hosts         )
    [[ -f /etc/nsswitch.conf ]] && NET_ARGS+=( --ro-bind /etc/nsswitch.conf /etc/nsswitch.conf )
    log_debug "Network enabled."
fi

# ── Home directory ────────────────────────────────────────────────────────────
HOME_ARGS=()
SANDBOX_HOME="/home/sandbox"

if [[ -n "$HOME_DIR" ]]; then
    HOME_DIR="$(realpath -m "$HOME_DIR")"
    [[ "$HOME_DIR" == "/"     ]] && die "--home cannot be the root directory"
    [[ "$HOME_DIR" == "/root" ]] && die "--home cannot be /root"
    mkdir -p "$HOME_DIR"
    HOME_ARGS=( --bind "$HOME_DIR" "$SANDBOX_HOME" )
    log_debug "Persistent home: $HOME_DIR -> $SANDBOX_HOME"
else
    HOME_ARGS=( --tmpfs "$SANDBOX_HOME" )
    log_debug "Ephemeral tmpfs home."
fi

# ── Extra binds ───────────────────────────────────────────────────────────────
EXTRA_ARGS=()
for _p in "${EXTRA_RO[@]+"${EXTRA_RO[@]}"}"; do
    [[ -z "$_p" ]] && continue
    _p="$(realpath -m "$_p")"
    case "$_p" in
        /proc/*|/sys/kernel/*|/root)
            log_warn "Suspicious --ro path skipped: $_p" ;;
        *)
            if [[ -e "$_p" ]]; then
                EXTRA_ARGS+=( --ro-bind "$_p" "$_p" )
                log_debug "Extra ro-bind: $_p"
            else
                log_warn "--ro path does not exist, skipped: $_p"
            fi ;;
    esac
done

for _p in "${EXTRA_RW[@]+"${EXTRA_RW[@]}"}"; do
    [[ -z "$_p" ]] && continue
    _p="$(realpath -m "$_p")"
    case "$_p" in
        /proc/*|/sys/*|/etc|/usr|/root)
            log_warn "Dangerous --rw path denied: $_p" ;;
        *)
            if [[ -e "$_p" ]]; then
                EXTRA_ARGS+=( --bind "$_p" "$_p" )
                log_debug "Extra rw-bind: $_p"
            else
                log_warn "--rw path does not exist, skipped: $_p"
            fi ;;
    esac
done

# ── Minimal /etc binds (not the whole /etc) ───────────────────────────────────
ETC_ARGS=()
for _f in \
    /etc/ld.so.cache /etc/ld.so.conf /etc/ld.so.conf.d \
    /etc/fonts /etc/ssl/certs /etc/ca-certificates \
    /etc/localtime /etc/locale.gen /etc/locale.conf \
    /etc/machine-id /etc/os-release \
    /etc/alternatives /etc/xdg \
    /etc/gtk-3.0 /etc/gtk-4.0 \
    /etc/pango /etc/dconf; do
    [[ -e "$_f" ]] && ETC_ARGS+=( --ro-bind "$_f" "$_f" )
done

# ── Assemble bwrap arguments ──────────────────────────────────────────────────
BWRAP_ARGS=(
    # Namespaces
    --unshare-user
    --unshare-ipc
    --unshare-pid
    --unshare-uts
    --unshare-cgroup-try
    "${NET_ARGS[@]}"

    # Drop all capabilities
    --cap-drop ALL

    # Base filesystem
    --tmpfs /
    --proc  /proc
    --dev   /dev
    --mqueue /dev/mqueue

    # System (read-only)
    --ro-bind /usr /usr
    --symlink usr/bin /bin
    --symlink usr/bin /sbin
    --symlink usr/lib /lib
    --symlink usr/lib /lib64

    # /etc: only required files (not the whole directory)
    --tmpfs /etc
    "${ETC_ARGS[@]}"

    # /var minimal
    --tmpfs /var
    --ro-bind-try /var/cache/fontconfig /var/cache/fontconfig

    # /tmp and /run
    --tmpfs /tmp
    --tmpfs /run
    --tmpfs "$SANDBOX_XRD_INSIDE"
    --chmod 0700 "$SANDBOX_XRD_INSIDE"

    # Wayland socket (empty in CLI mode)
    "${WAYLAND_SOCKET_ARGS[@]+"${WAYLAND_SOCKET_ARGS[@]}"}"

    # D-Bus proxy (session)
    "${DBUS_ARGS[@]+"${DBUS_ARGS[@]}"}"

    # D-Bus proxy (system)
    "${SYSTEM_DBUS_ARGS[@]+"${SYSTEM_DBUS_ARGS[@]}"}"

    # PipeWire
    "${PIPEWIRE_ARGS[@]+"${PIPEWIRE_ARGS[@]}"}"

    # GPU
    "${GPU_ARGS[@]+"${GPU_ARGS[@]}"}"

    # FIDO2/U2F
    "${FIDO_ARGS[@]+"${FIDO_ARGS[@]}"}"

    # Home
    "${HOME_ARGS[@]}"

    # Extra binds
    "${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"}"

    # Environment — clearenv, then only what is needed
    --clearenv
    --setenv HOME            "$SANDBOX_HOME"
    --setenv USER            "sandbox"
    --setenv LOGNAME         "sandbox"
    --setenv HOST            "$APP_NAME"
    --setenv HOSTNAME        "$APP_NAME"
    --setenv PATH            "/usr/bin:/usr/local/bin"
    --setenv SHELL           "/bin/bash"
    --setenv LANG            "${LANG:-C.UTF-8}"
    --setenv TERM            "${TERM:-xterm-256color}"
    --setenv XDG_RUNTIME_DIR "$SANDBOX_XRD_INSIDE"
    --setenv XDG_DATA_DIRS   "/usr/share:/usr/local/share"
    --setenv XDG_CONFIG_DIRS "/etc/xdg"

    # Wayland / CLI display envs
    "${WAYLAND_ENV_ARGS[@]}"

    # Security
    --new-session
    --die-with-parent
    --as-pid-1

    # The command
    "${CMD[@]}"
)

# ── Dry-run output ────────────────────────────────────────────────────────────
if [[ $DRY_RUN -eq 1 ]]; then
    printf '%s--- dry-run: bwrap command ---%s\n' "$C_BOLD" "$C_RESET" >&2
    printf '%q ' bwrap "${BWRAP_ARGS[@]}"
    printf '\n'
    exit 0
fi

if [[ $VERBOSE -eq 1 ]]; then
    log_debug "Starting: $APP_NAME ($APP_ID)"
    log_debug "Command:  ${CMD[*]}"
    log_debug "Wayland: $WAYLAND_MODE | net: $ENABLE_NET | dbus: $ENABLE_DBUS | system-dbus: $ENABLE_SYSTEM_DBUS | pipewire: $ENABLE_PIPEWIRE | gpu: $ENABLE_GPU | fido: $ENABLE_FIDO"
fi

# ── Execute ───────────────────────────────────────────────────────────────────
exec bwrap "${BWRAP_ARGS[@]}"
